{
  "name": "@sentinel-act/ticketing-adapter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run src/__tests__",
    "migrate": "tsx --env-file=.env src/migrations/cli.ts"
  },
  "dependencies": {
    "@sentinel-act/graph-schema": "workspace:*",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@sentinel-act/eslint-config": "workspace:*",
    "@sentinel-act/typescript-config": "workspace:*",
    "@testcontainers/postgresql": "^10.16.0",
    "testcontainers": "^10.16.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
