{
  "name": "@sentinel-act/assistant-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run test/*.test.ts",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "@sentinel-act/graph-db": "workspace:*",
    "@sentinel-act/graph-schema": "workspace:*",
    "@mastra/core": "^1.50.0",
    "neo4j-driver": "^5.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sentinel-act/eslint-config": "workspace:*",
    "@sentinel-act/typescript-config": "workspace:*",
    "@testcontainers/neo4j": "^10.16.0",
    "testcontainers": "^10.16.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
