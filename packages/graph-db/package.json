{
  "name": "@sentinel-act/graph-db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run test/repositories test/commit test/vector-search.test.ts test/migrations",
    "test:integration": "vitest run test/integration",
    "migrate": "tsx --env-file=.env src/migrations/cli.ts",
    "seed": "tsx --env-file=.env seed/seed.ts"
  },
  "dependencies": {
    "@sentinel-act/graph-schema": "workspace:*",
    "neo4j-driver": "^5.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@sentinel-act/eslint-config": "workspace:*",
    "@sentinel-act/typescript-config": "workspace:*",
    "@testcontainers/neo4j": "^10.16.0",
    "testcontainers": "^10.16.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
