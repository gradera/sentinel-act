# Local-dev defaults for @sentinel-act/graph-db.
# Full canonical variable set/table lives in
# docs/specs/15-ci-cd-environment-setup.md §4.1 — this file only covers
# the subset this package reads directly. Do not introduce new variable
# names here (e.g. GRAPH_DB_URL / VECTOR_STORE_URL are stale/retired
# names from an earlier draft — see docs/specs/README.md).

SENTINEL_NEO4J_URI=neo4j://localhost:7687
SENTINEL_NEO4J_USER=neo4j
SENTINEL_NEO4J_PASSWORD=sentinel-local-dev
SENTINEL_NEO4J_DATABASE=neo4j
