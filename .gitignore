# Sentinel Act — pnpm + Turborepo monorepo (Next.js web-console,
# Mastra/Node orchestrator, Neo4j-backed graph-db package).
# Kept organized by category so additions land in the right place.

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
# Scratch npm install used only to work around this sandbox's broken/
# incomplete pnpm store when verifying Spec 13 (packages/ticketing-adapter
# needs `pg`, which pnpm could not fully install here) — never a real
# dependency source, safe to delete and regenerate at any time.
.scratch-install/

# ---------------------------------------------------------------------------
# Env files — never commit real secrets. Ignore every .env* variant, then
# explicitly un-ignore the .env.example files (they document the required
# variables and are meant to be tracked).
# ---------------------------------------------------------------------------
.env*
!.env.example

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
next-env.d.ts
.turbo/
.mastra/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
# Vitest's transpiled config artifact — regenerated per run, occasionally
# left behind if a run is interrupted.
*.timestamp-*.mjs

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Caches
# ---------------------------------------------------------------------------
.eslintcache
.cache/

# ---------------------------------------------------------------------------
# Deployment tooling
# ---------------------------------------------------------------------------
.vercel/

# ---------------------------------------------------------------------------
# Local TLS certs sometimes used for HTTPS dev servers
# ---------------------------------------------------------------------------
*.pem

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Editor / IDE (user-local settings only — do not add shared project
# config here if the team ever decides to check in .vscode/settings.json)
# ---------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~
