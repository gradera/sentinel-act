# Full variable set per docs/specs/15-ci-cd-environment-setup.md §4.1
# (the canonical env var table — if code references a var not listed
# here, that's a bug per that spec's FR-1/FR-2).

# --- Model provider (Specs 03, 04, 06) ---
# Swapped in through Mastra's model router, so the schema is not coupled
# to a single vendor.
MODEL_PROVIDER_API_KEY=
OBLIGATION_EXTRACTION_MODEL_ID=anthropic/claude-sonnet-4-5
GROUNDING_VERIFICATION_MODEL_ID=anthropic/claude-opus-4-6
CHANGE_AND_DELTA_ALIGNMENT_MODEL_ID=

# --- Regulatory Watch and Ingestion (Spec 02) ---
# Comma-separated if more than one listing page is polled.
SEBI_LISTING_URLS=https://www.sebi.gov.in/sebiweb/home/HomeAction.do?doListing=yes
REGULATORY_WATCH_POLL_CRON=0 */4 * * *

# --- Regulatory Knowledge Graph (Neo4j, Spec 01) ---
SENTINEL_NEO4J_URI=neo4j://localhost:7687
SENTINEL_NEO4J_USER=neo4j
SENTINEL_NEO4J_PASSWORD=
SENTINEL_NEO4J_DATABASE=neo4j
# Left unset by default: GraphRAG (Clause.embedding_ref) uses Neo4j's own
# native vector index in the same instance, not a separate store. Only
# set this if the team later splits out a dedicated vector store
# (open question in Spec 01).
SENTINEL_VECTOR_STORE_URL=

# --- Conversational Assistant read-only credential (Spec 12) ---
# Deliberately a separate, minimally-privileged Neo4j user from
# SENTINEL_NEO4J_* above — hard DB-level enforcement that this surface
# cannot write to the graph (Spec 12 §7 NFR-5).
SENTINEL_NEO4J_ASSISTANT_URI=neo4j://localhost:7687
SENTINEL_NEO4J_ASSISTANT_USER=
SENTINEL_NEO4J_ASSISTANT_PASSWORD=
ASSISTANT_MODEL_ID=
ASSISTANT_RATE_LIMIT_PER_MINUTE=20

# --- Hash-chained Audit Ledger (Postgres, Spec 07) ---
SENTINEL_AUDIT_LEDGER_DATABASE_URL=postgres://sentinel:sentinel@localhost:5432/sentinel_ledger

# --- EvidenceArtifact object storage (Spec 07, S3-compatible) ---
EVIDENCE_STORAGE_BUCKET=sentinel-evidence-local
EVIDENCE_STORAGE_ACCESS_KEY_ID=
EVIDENCE_STORAGE_SECRET_ACCESS_KEY=
EVIDENCE_STORAGE_ENDPOINT=http://localhost:9000

# --- Slack Channels and Signals (Spec 11) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
WEB_CONSOLE_BASE_URL=http://localhost:3000
SLA_POLL_INTERVAL_MINUTES=5
SLA_DUE_SOON_WINDOW_HOURS=4

# --- GRC/Ticketing Integration (Spec 13) ---
TICKETING_ADAPTER=generic-webhook
TICKETING_WEBHOOK_URL=
TICKETING_WEBHOOK_SECRET=
TICKETING_DEFAULT_QUEUE_REF=

# --- Web console BFF <-> Orchestrator service credential (Spec 09/15) ---
SENTINEL_SERVICE_JWT_SECRET=dev-only-placeholder-not-a-real-secret

NODE_ENV=development
