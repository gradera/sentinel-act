# Model provider key for the LLM-backed agents (Obligation Extraction,
# Grounding and Verification). Swapped in through Mastra's model router,
# so the schema is not coupled to a single vendor.
MODEL_PROVIDER_API_KEY=

# SEBI circular listing URL polled by the Regulatory Watch and Ingestion agent.
SEBI_CIRCULARS_URL=https://www.sebi.gov.in/sebiweb/home/HomeAction.do?doListing=yes

# Graph + vector store connection (Regulatory Knowledge Graph / System of Record).
GRAPH_DB_URL=
VECTOR_STORE_URL=

# Slack app credentials for the Signals / quick-approve channel.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
