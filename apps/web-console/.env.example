# Full variable set per docs/specs/15-ci-cd-environment-setup.md §4.1
# FR-3 (this file did not previously exist — created as part of the
# post-review due-diligence pass on the spec set).

ORCHESTRATOR_BASE_URL=http://localhost:4111
SENTINEL_SERVICE_JWT_SECRET=dev-only-placeholder-not-a-real-secret

NEXTAUTH_SECRET=dev-only-placeholder-not-a-real-secret
NEXTAUTH_URL=http://localhost:3000

# Spec 09 Task 10 (spec-09-stage-2) — signs/verifies the
# `sentinel_reviewer_session` cookie (lib/console/session-jwt.ts). Distinct
# from both NEXTAUTH_SECRET above (unused — next-auth is not an installed
# dependency of this app) and SENTINEL_SERVICE_JWT_SECRET (that one
# authenticates this app's BFF to apps/orchestrator, a different trust
# boundary — see lib/console/session.ts's doc comment). Nothing mints this
# cookie yet (no login screen built in this stage); until one exists,
# lib/console/dev-session.ts's header-based bridge is how local dev
# authenticates as a reviewer (NODE_ENV !== "production" only).
REVIEWER_SESSION_SECRET=dev-only-placeholder-not-a-real-secret

NEXT_PUBLIC_ENVIRONMENT_TIER=local
NODE_ENV=development

# Spec 10 §5.5/FR-12/FR-13 (Compliance Register Export sync-vs-async
# routing) + §13 Open Question 8. Both are unbenchmarked hackathon-scale
# placeholders, deliberately made configurable so they can be tuned once
# real export sizes/concurrency are observed, without a code change.
# Row-count estimate <= this value: generate synchronously in-request
# (200, file streamed back). Above it: create a queued :ExportJob (202)
# and generate in the background instead (see app/api/audit/export/route.ts's
# top-of-file comment for the honest limitation of this app's "async" path).
AUDIT_EXPORT_SYNC_ROW_THRESHOLD=500
# Max :ExportJob nodes with status queued|running at once (NFR-7). A
# request that would exceed this while over the sync threshold above gets
# 429 TOO_MANY_CONCURRENT_EXPORTS instead of a new queued job.
AUDIT_EXPORT_MAX_CONCURRENT_JOBS=3
