        <mxCell id="1" parent="0"/>
        <mxCell id="n101" value="Sentinel Act: System Architecture" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontColor=#1B1F4B;fontSize=22;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="0" y="8" width="1200" height="30" as="geometry"/></mxCell><mxCell id="n102" value="Agent runtime orchestrated around a bitemporal Regulatory Knowledge Graph as the system of record" style="text;html=1;align=center;verticalAlign=middle;fontColor=#595959;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="0" y="40" width="1200" height="20" as="geometry"/></mxCell><mxCell id="n103" value="SOURCES" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="68" width="400" height="18" as="geometry"/></mxCell><mxCell id="n104" value="REGULATORY WATCH" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="168" width="400" height="18" as="geometry"/></mxCell><mxCell id="n105" value="ORCHESTRATION (deterministic, not an LLM)" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="263" width="500" height="18" as="geometry"/></mxCell><mxCell id="n106" value="AGENT LAYER" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="373" width="400" height="18" as="geometry"/></mxCell><mxCell id="n107" value="SYSTEM OF RECORD" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="508" width="400" height="18" as="geometry"/></mxCell><mxCell id="n108" value="HUMAN GOVERNANCE (tiered)" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="628" width="400" height="18" as="geometry"/></mxCell><mxCell id="n109" value="OBSERVABILITY" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="738" width="400" height="18" as="geometry"/></mxCell><mxCell id="n110" value="OUTPUTS" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="833" width="400" height="18" as="geometry"/></mxCell><mxCell id="n111" value="ADD-ON (OPTIONAL)" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontColor=#5B2A9E;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="60" y="938" width="400" height="18" as="geometry"/></mxCell><mxCell id="n112" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;SEBI Circular Listings&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;HTML pages, polled on schedule&lt;/font&gt;" style="rounded=1;arcSize=33;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="60" y="92" width="340" height="60" as="geometry"/></mxCell><mxCell id="n113" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Master Circulars&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Stockbrokers + Investment Advisers&lt;/font&gt;" style="rounded=1;arcSize=33;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="430" y="92" width="340" height="60" as="geometry"/></mxCell><mxCell id="n114" value="&lt;font color='#FFFFFF' style='font-size:13px;font-weight:bold'&gt;3 Jul 2026 Amendment&lt;/font&gt;&lt;br&gt;&lt;font color='#EEEDFE' style='font-size:10px;font-weight:normal'&gt;Para 46, CUSPA: flagship live-demo input&lt;/font&gt;" style="rounded=1;arcSize=33;whiteSpace=wrap;html=1;fillColor=#8A2BE2;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="800" y="92" width="340" height="60" as="geometry"/></mxCell><mxCell id="n115" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Regulatory Watch and Ingestion Agent&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Scheduled polling (cron) + automated browser fetch&lt;/font&gt;" style="rounded=1;arcSize=36;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="390" y="192" width="420" height="55" as="geometry"/></mxCell><mxCell id="n120" value="&lt;font color='#FFFFFF' style='font-size:13px;font-weight:bold'&gt;Workflow Orchestrator (control plane)&lt;/font&gt;&lt;br&gt;&lt;font color='#EEEDFE' style='font-size:10px;font-weight:normal'&gt;propose, verify, risk-score, commit. Native suspend / resume drives the human-in-the-loop tiers below&lt;/font&gt;&lt;br&gt;&lt;font color='#EEEDFE' style='font-size:10px;font-weight:normal'&gt;Nothing here is an LLM decision&lt;/font&gt;" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#1B1F4B;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="60" y="287" width="1080" height="70" as="geometry"/></mxCell><mxCell id="n121" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Obligation Extraction&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;LLM-backed AI agent&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;clause to structured Obligation&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;+ confidence score&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="60" y="397" width="204" height="95" as="geometry"/></mxCell><mxCell id="n122" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Grounding and Verification&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Independent LLM critic pass&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;checks extraction vs source&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;flags contradictions&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="279" y="397" width="204" height="95" as="geometry"/></mxCell><mxCell id="n123" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Mapping and Risk Scoring&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Deterministic, rules based&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Obligation to ProcessTask&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;+ review priority score&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="498" y="397" width="204" height="95" as="geometry"/></mxCell><mxCell id="n124" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Change and Delta&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Structural graph diff&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;pre vs post amendment&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;drafts redlined update&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="717" y="397" width="204" height="95" as="geometry"/></mxCell><mxCell id="n125" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Monitoring and Audit&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Deterministic, rules based&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;tracks fulfilment + evidence&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;flags gaps, logs decisions&lt;/font&gt;" style="rounded=1;arcSize=21;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="936" y="397" width="204" height="95" as="geometry"/></mxCell><mxCell id="n132" value="&lt;font color='#FFFFFF' style='font-size:13px;font-weight:bold'&gt;Regulatory Knowledge Graph&lt;/font&gt;&lt;br&gt;&lt;font color='#EEEDFE' style='font-size:10px;font-weight:normal'&gt;Bitemporal: valid_from / valid_to / recorded_at&lt;/font&gt;&lt;br&gt;&lt;font color='#EEEDFE' style='font-size:10px;font-weight:normal'&gt;Circular, Clause, Obligation, ProcessTask, Evidence&lt;/font&gt;" style="rounded=1;arcSize=25;whiteSpace=wrap;html=1;fillColor=#5B2A9E;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="60" y="532" width="420" height="80" as="geometry"/></mxCell><mxCell id="n133" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Vector Store&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;GraphRAG: semantic&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;clause retrieval, distinct from the KG&lt;/font&gt;" style="rounded=1;arcSize=25;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="500" y="532" width="300" height="80" as="geometry"/></mxCell><mxCell id="n134" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Hash-chained Audit Ledger&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;SHA-256, tamper evident&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Monitoring and Audit writes here&lt;/font&gt;" style="rounded=1;arcSize=25;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="820" y="532" width="320" height="80" as="geometry"/></mxCell><mxCell id="n142" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Tier A / B / C Router&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;risk and confidence based routing&lt;/font&gt;" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="60" y="652" width="255" height="70" as="geometry"/></mxCell><mxCell id="n143" value="&lt;font color='#FFFFFF' style='font-size:13px;font-weight:bold'&gt;Web Governance Console&lt;/font&gt;&lt;br&gt;&lt;font color='#EEEDFE' style='font-size:10px;font-weight:normal'&gt;lineage, redline diff, comments&lt;/font&gt;&lt;br&gt;&lt;font color='#EEEDFE' style='font-size:10px;font-weight:normal'&gt;maker-checker sign-off&lt;/font&gt;" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#8A2BE2;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="335" y="652" width="255" height="70" as="geometry"/></mxCell><mxCell id="n144" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Slack Channels&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;approve / decline cards, quick path&lt;/font&gt;" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="610" y="652" width="255" height="70" as="geometry"/></mxCell><mxCell id="n145" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Signals&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;SLA due-by reminders to reviewers&lt;/font&gt;" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="885" y="652" width="255" height="70" as="geometry"/></mxCell><mxCell id="n150" value="&lt;font color='#5B2A9E' style='font-size:13px;font-weight:bold'&gt;Observability Console&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Live execution graph, tracing, and step-by-step replay of every stage above&lt;/font&gt;" style="rounded=1;arcSize=36;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#8A2BE2;strokeWidth=1.6;dashed=1;dashPattern=6 3;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="290" y="762" width="620" height="55" as="geometry"/></mxCell><mxCell id="n152" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;GRC / Ticketing Integration&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;ProcessTask objects become real operational tickets&lt;/font&gt;" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="60" y="857" width="510" height="70" as="geometry"/></mxCell><mxCell id="n153" value="&lt;font color='#1B1F4B' style='font-size:13px;font-weight:bold'&gt;Compliance Register Export&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Regulator-ready PDF / Excel, point-in-time queryable&lt;/font&gt;" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#1B1F4B;strokeWidth=1.4;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="630" y="857" width="510" height="70" as="geometry"/></mxCell><mxCell id="n156" value="&lt;font color='#5B2A9E' style='font-size:13px;font-weight:bold'&gt;Conversational Assistant (Open WebUI style chat)&lt;/font&gt;&lt;br&gt;&lt;font color='#595959' style='font-size:10px;font-weight:normal'&gt;Plain-English Q&amp;A over the Knowledge Graph and Vector Store, read-only, cannot commit changes&lt;/font&gt;" style="rounded=1;arcSize=28;whiteSpace=wrap;html=1;fillColor=#F1ECFB;strokeColor=#8A2BE2;strokeWidth=1.6;dashed=1;dashPattern=6 3;align=center;verticalAlign=middle;fontFamily=Helvetica;spacing=4;" vertex="1" parent="1"><mxGeometry x="290" y="962" width="620" height="70" as="ge